LLM_PROVIDER=openai
LLM_MODEL=deepseek-chat
OPENAI_API_BASE=https://api.deepseek.com
OPENAI_API_KEY=your-api-key-here

# For Google Gemini: LLM_PROVIDER=gemini, GOOGLE_API_KEY=...
# For Anthropic:     LLM_PROVIDER=anthropic, ANTHROPIC_API_KEY=...
# For local Ollama:  LLM_PROVIDER=ollama, LLM_MODEL=llama3

DATABASE_URL=postgresql+asyncpg://user:password@localhost:5433/sf_localization
LOG_LEVEL=INFO
TRANSLATE_BATCH_SIZE=5
